rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /userProfile/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024 // Enforce 2MB size limit
                   && request.resource.contentType.matches('image/.*'); // Enforce image type only
    }
  }
}
